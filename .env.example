# Contoh environment variables. Di Railway, isi ini di tab "Variables".
# Untuk tes lokal, boleh dikosongkan (ada default 'changeme').

# Token Cloudflare Tunnel (Zero Trust > Tunnels). KOSONGKAN buat tes lokal.
CF_TUNNEL_TOKEN=

# Password buat buka halaman web terminal (sshwifty)
SSHWIFTY_SHAREDKEY=ganti-password-ini

# Password login user 'app' di dalam container
SSH_PASSWORD=ganti-password-ini

# Token rahasia frps — WAJIB kuat! (TCP Proxy Railway kebuka ke dunia)
FRP_TOKEN=ganti-token-acak-yang-panjang

# User default buat login ke 3 mesin Ubuntu (bisa diubah di preset)
MACHINE_USER=ubuntu
